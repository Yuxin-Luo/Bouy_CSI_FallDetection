# Timer durations (milliseconds) — keep small for demo
T1_MS=45000
T2_MS=120000
T3_MS=180000

# Pusher — get from pusher.com dashboard
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=us2
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=us2

# Twilio — get from twilio.com console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Public URL of the deployed server (used in SMS links)
BASE_URL=http://localhost:3001

# Server port
PORT=3001
