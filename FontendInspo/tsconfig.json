import { createFileRoute, Link } from "@tanstack/react-router";
import { useState } from "react";
import { CheckCircle2, ShieldCheck, Smartphone, Radio, Heart } from "lucide-react";

export const Route = createFileRoute("/resident/")({
  head: () => ({ meta: [{ title: "You're all set — Hearth" }] }),
  component: ResidentHome,
});

function ResidentHome() {
  const [alertOpen, setAlertOpen] = useState(false);
  return (
    <div className="space-y-6">
      <section className="rounded-3xl bg-gradient-to-br from-primary to-[oklch(0.42_0.08_150)] text-primary-foreground p-7 relative overflow-hidden">
        <div className="absolute -right-10 -top-10 h-40 w-40 rounded-full bg-accent/30 blur-3xl" />
        <p className="text-sm opacity-80 relative">Sunday afternoon</p>
        <h1 className="font-serif text-4xl mt-1 relative">You're all set, Margaret.</h1>
        <p className="opacity-90 mt-2 relative">
          Your home is being watched gently. Sarah and James are nearby if you need them.
        </p>
      </section>

      <button
        onClick={() => setAlertOpen(true)}
        className="w-full rounded-2xl border border-dashed border-border bg-card p-4 text-sm text-muted-foreground hover:border-accent hover:text-foreground transition"
      >
        Preview the "Are you okay?" screen
      </button>

      <div className="grid grid-cols-2 gap-3">
        <StatusTile Icon={ShieldCheck} title="Fall detection" status="Active" tone="ok" />
        <StatusTile Icon={Radio} title="Home sensors" status="3 of 4 OK" tone="warn" />
        <StatusTile Icon={Smartphone} title="Phone fall detect" status="Off" tone="muted" />
        <StatusTile Icon={Heart} title="You" status="Doing well" tone="ok" />
      </div>

      <div className="rounded-2xl bg-card border border-border/60 p-5 shadow-[var(--shadow-soft)]">
        <h2 className="font-serif text-2xl">In case of a fall</h2>
        <p className="text-sm text-muted-foreground mt-1">
          If Hearth thinks you've fallen, a big "Are you okay?" screen will appear. Tap "I'm fine" and nobody will be bothered.
        </p>
        <Link
          to="/resident/caregivers"
          className="mt-4 inline-flex items-center text-sm text-primary hover:underline"
        >
          See who would be called →
        </Link>
      </div>

      {alertOpen && <AlertPreview onCancel={() => setAlertOpen(false)} />}
    </div>
  );
}

function StatusTile({
  Icon,
  title,
  status,
  tone,
}: {
  Icon: typeof Heart;
  title: string;
  status: string;
  tone: "ok" | "warn" | "muted";
}) {
  const cls =
    tone === "ok" ? "bg-primary-soft text-primary"
    : tone === "warn" ? "bg-accent text-accent-foreground"
    : "bg-secondary text-muted-foreground";
  return (
    <div className="rounded-2xl bg-card border border-border/60 p-4 shadow-[var(--shadow-soft)]">
      <div className={`h-9 w-9 rounded-xl flex items-center justify-center ${cls}`}>
        <Icon className="h-4 w-4" />
      </div>
      <p className="text-xs text-muted-foreground mt-3">{title}</p>
      <p className="font-medium text-foreground">{status}</p>
    </div>
  );
}

function AlertPreview({ onCancel }: { onCancel: () => void }) {
  const [cancelled, setCancelled] = useState(false);
  return (
    <div className="fixed inset-0 z-40 bg-background flex flex-col items-center justify-center p-6 text-center animate-in fade-in">
      {cancelled ? (
        <>
          <div className="h-20 w-20 rounded-full bg-primary-soft text-primary flex items-center justify-center">
            <CheckCircle2 className="h-10 w-10" />
          </div>
          <h2 className="font-serif text-3xl mt-6">Thanks for letting us know</h2>
          <p className="text-muted-foreground mt-2 max-w-sm">
            We told Sarah and James that you're okay and cancelled the alert.
          </p>
          <button
            onClick={onCancel}
            className="mt-8 rounded-full border border-border px-5 py-2.5 text-sm"
          >
            Close
          </button>
        </>
      ) : (
        <>
          <div className="h-3 w-32 rounded-full bg-accent animate-pulse mb-6" />
          <p className="text-sm uppercase tracking-wider text-accent-foreground">Possible fall detected</p>
          <h2 className="font-serif text-5xl mt-3">Are you okay?</h2>
          <p className="text-muted-foreground mt-3 max-w-sm">
            We'll call Sarah in <span className="font-medium text-foreground">30 seconds</span> unless you tap below.
          </p>
          <button
            onClick={() => setCancelled(true)}
            className="mt-8 w-full max-w-xs rounded-3xl bg-primary text-primary-foreground py-8 text-2xl font-serif shadow-[var(--shadow-soft)] hover:opacity-90 transition"
          >
            I'm fine
          </button>
          <button
            onClick={onCancel}
            className="mt-3 text-sm text-muted-foreground"
          >
            (preview — close)
          </button>
        </>
      )}
    </div>
  );
}
