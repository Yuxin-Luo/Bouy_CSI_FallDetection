# Dependencies
node_modules

# Environment / credentials — NEVER commit these
.env
.env.local
.env*.local

# Database
*.db
*.db-wal
*.db-shm
apps/server/data

# Build output
apps/web/.next
apps/web/out
dist

# Internal notes
CLAUDE_CODE_BRIEF.md
NOTES.md

# OS
.DS_Store
**/.DS_Store
Thumbs.db

# TypeScript / Next.js
*.tsbuildinfo
next-env.d.ts

# Logs
npm-debug.log*
yarn-debug.log*

# Vercel
.vercel

# Python
__pycache__
*.pyc
*.pyo
.pytest_cache

# ESP-IDF / ESP32 firmware (fall-detection-training/)
# Per README.md: "the full esp-csi/ SDK clone is excluded from git"
fall-detection-training/firmware/esp-csi/
# Backup of upstream files before applying bouy patch
fall-detection-training/firmware/.original_esp-csi_backup/
# IDF build artifacts (per-project build/ dirs under each example)
fall-detection-training/firmware/**/build/
fall-detection-training/firmware/**/sdkconfig
fall-detection-training/firmware/**/sdkconfig.old
fall-detection-training/firmware/**/dependencies.lock
# Compiled firmware images
*.elf
*.bin
*.map

# Backup files (e.g. firmware_patches/.csi_*_app_main.c.bouy_v1.bak)
*.bak

# CSI captures + live chunks (large binary blobs, regenerate from hardware anytime)
# Per 2026-06-30 review: data/ + capture_*.npz + chunk_*.npz were not ignored
# before, which let accidental `git add -A` commit MB-sized CSI blobs.
# capture_multi.py now defaults to <project>/data/raw/ (was relative — bug fixed).
data/
# Recorded session datasets (per-session NPZ/HDF blobs from multi-RX capture)
dataset/
**/capture_*.npz
**/chunk_*.npz
